# ============================================================
# Copy this file to server/.env and fill in your own values
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=employee_management

# JWT
JWT_SECRET=123456
JWT_EXPIRES_IN=1d

# CORS (frontend origin, e.g. if served by a separate static server)
CLIENT_ORIGIN=http://localhost:5500
